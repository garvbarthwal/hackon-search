{
  "name": "shopping-cart-ai",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "seed:products": "tsx src/scripts/seedProducts.ts",
    "seed:categories": "tsx src/scripts/seedCategories.ts",
    "seed:missions": "tsx src/scripts/seedMissions.ts",
    "embed:products": "tsx src/scripts/embedProducts.ts",
    "extract:brands": "tsx src/scripts/extractBrands.ts",
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "eval": "tsx src/scripts/eval.ts"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.1068.0",
    "@google/genai": "^0.7.0",
    "@prisma/client": "^5.22.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.9.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
